{
  "name": "zerogpu",
  "version": "0.1.1",
  "description": "Official ZeroGPU API client for Node.js and TypeScript",
  "license": "MIT",
  "homepage": "https://docs.zerogpu.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerogpu/SDK.git",
    "directory": "npm"
  },
  "bugs": {
    "url": "https://github.com/zerogpu/SDK/issues"
  },
  "keywords": [
    "zerogpu",
    "ai",
    "sdk",
    "inference",
    "typescript",
    "nodejs"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
